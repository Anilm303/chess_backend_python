FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=7860
PASSWORD_RESET_RETURN_TOKEN=true
# PostgreSQL connection for production/local dev. Replace placeholders below.
# Example (local Postgres):
# DATABASE_URL=postgresql://postgres:YourPassword@localhost:5432/chess
# For cloud providers use: postgresql://user:pass@host:5432/dbname?sslmode=require

DATABASE_URL=postgresql://postgres:Rana1515@localhost:5432/chess_db

# Environment: development | production (used by /payments/esewa/test_mark_paid to gate)
ENV=development

# eSewa payment configuration
# Use EPAYTEST for sandbox/UAT (https://uat.esewa.com.np/epay).
# For production, set ESEWA_MERCHANT_ID to your real merchant code.
ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_SECRET=
# Public HTTPS URL exposed to eSewa. For local dev use an ngrok URL.
ESEWA_SUCCESS_URL=https://your-ngrok-domain.ngrok.io/api/payments/esewa/callback
ESEWA_FAIL_URL=https://your-ngrok-domain.ngrok.io/api/payments/esewa/callback?status=failed
BASE_URL=https://your-ngrok-domain.ngrok.io
