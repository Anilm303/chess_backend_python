# Flask backend production variables
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret
FLASK_HOST=0.0.0.0
FLASK_PORT=7860
FLASK_DEBUG=false
PORT=7860
ALLOWED_ORIGINS=https://app.yourdomain.com,https://yourdomain.com
MAX_CONTENT_LENGTH=104857600
MEDIA_STORAGE=s3
MEDIA_PUBLIC_BASE_URL=https://cdn.yourdomain.com

# Optional cloud dependencies for production
DATABASE_URL=postgresql://user:password@host:5432/chess
REDIS_URL=redis://:password@host:6379/0
S3_BUCKET=your-media-bucket
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# FCM service account path if you want push notifications
# serviceAccountKey.json should be mounted or copied into the container securely
